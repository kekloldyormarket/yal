# RPC endpoint for client + server reads
NEXT_PUBLIC_RPC=https://rpc.ironforge.network/mainnet?apiKey=01KSG5964GKG2V5B0CZDX3X3WY

# Vercel Blob — image + metadata uploads for /launch
# Auto-provisioned on Vercel after enabling the Blob integration in the
# project. For local dev: `vercel link && vercel env pull .env.local`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Optional: shared Meteora DBC config pubkey. Without it, the launch page
# stays in mock mode (image+metadata still upload to Blob, but the on-chain
# tx is a 1.8s timer simulation). See frontend/lib/launch-tx.ts.
# NEXT_PUBLIC_YAL_DBC_CONFIG=

# Optional override of the deployed router (defaults to mainnet 9zMMi7n…)
# NEXT_PUBLIC_YAL_PROGRAM_ID=
